# Baileys Configuration
BAILEYS_LOG_LEVEL=error
WHATSAPP_BROWSER_NAME=Chrome

# Logging (silent, fatal, error, warn, info, debug, trace)
LOG_LEVEL=info

# Database
DB_HOST=localhost
DB_DIALECT=postgres
DB_PORT=5432
DB_NAME=whaticket
DB_USER=root
DB_PASS=

# JWT Secrets
JWT_SECRET=mysecret
JWT_REFRESH_SECRET=myanothersecret

# Server port (the Express HTTP server listens on this port)
PORT=3000

# Backend URL
BACKEND_URL=http://localhost:8080

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Proxy
PROXY_PORT=8080

# Redis
IO_REDIS_SERVER=127.0.0.1
IO_REDIS_PASSWORD=
IO_REDIS_PORT=6379
IO_REDIS_DB_SESSION=2

# Redis URL (required for BullMQ job queues, rate limiting, and list cache)
# Format: redis://[:password@]host[:port][/db]
REDIS_URL=redis://localhost:6379/0

# Instagram Business Login API
# Crie um app em https://developers.facebook.com/ com produto
# "Instagram > API setup with Instagram Login".
# Redirect URI: {BACKEND_URL}/instagram/oauth/callback
# Webhook callback: {BACKEND_URL}/instagram/webhook
IG_APP_ID=
IG_APP_SECRET=
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=whaticket_ig_verify

# WhatsApp Cloud API (Meta)
# Crie um app em https://developers.facebook.com/ com produto "WhatsApp".
# System User Access Token: em business.facebook.com → System Users → gere token com permissão whatsapp_business_messaging
# Webhook callback: {BACKEND_URL}/whatsapp-cloud/webhook
WA_CLOUD_APP_SECRET=
WA_CLOUD_WEBHOOK_VERIFY_TOKEN=whaticket_wac_verify

# Scalability tuning
# Number of concurrent inbound message workers (default: 5)
MESSAGE_WORKER_CONCURRENCY=5
# Maximum outbound WhatsApp messages per minute per session (default: 20)
OUTBOUND_RATE_LIMIT=20
